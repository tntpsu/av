{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av.local/schemas/triage_packet.schema.json",
  "title": "Triage Packet",
  "type": "object",
  "required": [
    "schema_version",
    "git_sha",
    "config_hash",
    "matrix_hash",
    "recording_ids",
    "pass_fail",
    "regression_budget",
    "root_cause_bucket",
    "first_divergence_frame",
    "first_infeasible_frame",
    "first_speed_above_feasibility_frame",
    "source_at_failure",
    "telemetry_completeness"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "git_sha": {
      "type": "string"
    },
    "config_hash": {
      "type": "string"
    },
    "matrix_hash": {
      "type": "string"
    },
    "recording_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pass_fail": {
      "type": "boolean"
    },
    "regression_budget": {
      "type": "object"
    },
    "root_cause_bucket": {
      "type": "string",
      "enum": [
        "curvature_contract_failure",
        "controller_authority_failure",
        "longitudinal_overspeed",
        "sampling_invalid"
      ]
    },
    "first_divergence_frame": {
      "type": [
        "integer",
        "null"
      ]
    },
    "first_infeasible_frame": {
      "type": [
        "integer",
        "null"
      ]
    },
    "first_speed_above_feasibility_frame": {
      "type": [
        "integer",
        "null"
      ]
    },
    "source_at_failure": {
      "type": "string"
    },
    "telemetry_completeness": {
      "type": "object",
      "required": [
        "curvature_contract",
        "feasibility"
      ],
      "properties": {
        "curvature_contract": {
          "type": [
            "number",
            "null"
          ]
        },
        "feasibility": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  },
  "additionalProperties": true
}
